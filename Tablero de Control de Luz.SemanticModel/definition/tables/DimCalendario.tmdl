		sourceColumn: [EsFinDeSemana]

		annotation SummarizationSetBy = Automatic

	partition DimCalendario = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    CALENDAR(
				        DATE(2026,1,1),
				        DATE(2026,12,31)
				    ),
				    "Año", YEAR([Date]),
				    "MesNro", MONTH([Date]),
				    "Mes", FORMAT([Date], "MMMM"),
				    "MesCorto", FORMAT([Date], "MMM"),
				    "Trimestre", "T" & QUARTER([Date]),
				    "Dia", DAY([Date]),
				    "DiaSemanaNro", WEEKDAY([Date], 2),
				    "DiaSemana", FORMAT([Date], "dddd"),
				    "SemanaAño", WEEKNUM([Date], 2),
				    "AñoMes", FORMAT([Date], "YYYY-MM"),
				    "AñoMesTexto", FORMAT([Date], "YYYY MMM"),
				    "EsFinDeSemana",
				        IF(WEEKDAY([Date], 2) >= 6, "Sí", "No")
				)

	annotation PBI_Id = 12198ced98c74e978bb5609cf968d8d2

